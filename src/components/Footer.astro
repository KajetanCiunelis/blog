---
interface Props {
  lang: 'pl' | 'en';
}

const { lang } = Astro.props;
const year = 2026;
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <p>© {year} Kajetan Ciunelis<br />CC BY 4.0</p>
    </div>
    <div class="footer-center">
      <p>
        <a href="https://github.com/KajetanCiunelis" rel="me">GitHub</a> ·
        <a href="https://www.instagram.com/kajetan.ciunelis/" rel="me">Instagram</a> ·
        <a href="https://orcid.org/0009-0007-4168-9122" rel="me">ORCID</a> ·
        <a href="mailto:kajetan.ciunelis@awf.edu.pl">kajetan.ciunelis@awf.edu.pl</a>
      </p>
    </div>
    <div class="footer-right">
      <p>
        {lang === 'en' ? 'Built with' : 'Zbudowane z'}
        <a href="https://astro.build">Astro</a>
      </p>
    </div>
  </div>
</footer>
