---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { slugify } from '../utils/helpers';

interface Props {
  lang: 'pl' | 'en';
}

const { lang } = Astro.props;
const poems = (await getCollection('poems', ({ data }) => data.lang === lang)).sort(
  (a, b) => a.data.order - b.data.order
);

const rendered = await Promise.all(
  poems.map(async (poem) => ({
    poem,
    anchor: slugify(poem.data.title),
    Content: (await render(poem)).Content,
  }))
);

const path = lang === 'en' ? '/en/poetry/' : '/poetry/';
const title = lang === 'en' ? 'Poetry' : 'Poezja';
const description =
  lang === 'en'
    ? 'Poems by Kajetan Ciunelis — on sourdough, biodegradation, and reasons.'
    : 'Wiersze Kajetana Ciunelisa — o zakwasie, biodegradacji i powodach.';
const tocTitle = lang === 'en' ? 'Poems' : 'Wiersze';
---

<Base
  title={title}
  description={description}
  lang={lang}
  path={path}
  alternates={{ pl: '/poetry/', en: '/en/poetry/' }}
  switchHref={lang === 'en' ? '/poetry/' : '/en/poetry/'}
>
  <h1>{title}</h1>

  {
    rendered.length > 1 && (
      <nav aria-label={tocTitle}>
        <ul class="poem-toc">
          {rendered.map(({ poem, anchor }) => (
            <li>
              <a href={`#${anchor}`}>{poem.data.title}</a>
            </li>
          ))}
        </ul>
      </nav>
    )
  }

  <div data-pagefind-body>
    {
      rendered.map(({ poem, anchor, Content }, i) => (
        <section>
          {i > 0 && <hr />}
          <h2 id={anchor}>{poem.data.title}</h2>
          <div class="poem">
            <Content />
          </div>
        </section>
      ))
    }
  </div>
</Base>
