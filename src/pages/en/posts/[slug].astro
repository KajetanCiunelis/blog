---
import { getCollection } from 'astro:content';
import PostPage from '../../../components/PostPage.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('postsEn', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  );
  return posts.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: i > 0 ? { slug: posts[i - 1].id, title: posts[i - 1].data.title } : null,
      next:
        i < posts.length - 1
          ? { slug: posts[i + 1].id, title: posts[i + 1].data.title }
          : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
---

<PostPage entry={entry} lang="en" prev={prev} next={next} />
